---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | GitOrbit">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-8xl font-bold text-accent mb-4">404</h1>
      <p class="text-xl text-text-secondary mb-8">Page not found</p>
      <a 
        href="/" 
        class="inline-flex items-center px-6 py-3 rounded-lg bg-accent hover:bg-accent-hover text-white font-medium transition-colors"
      >
        Go Home
      </a>
    </div>
  </main>
</BaseLayout>
