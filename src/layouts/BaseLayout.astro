---
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Your entire GitHub universe, one orbit away.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://gitorbit.oriz.in" />
    <meta property="og:image" content="https://gitorbit.oriz.in/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col nebula-bg">
    <!-- ═══════════ Star Field (pure CSS) ═══════════ -->
    <div class="stars pointer-events-none fixed inset-0 z-0" />

    <!-- ═══════════ Navbar ═══════════ -->
    <nav class="relative z-50 border-b border-border/60 glass sticky top-0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <div class="relative">
              <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center transition-transform group-hover:scale-110 glow-ring">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 1.5a8.5 8.5 0 1 1 0 17 8.5 8.5 0 0 1 0-17z" opacity="0.4" />
                </svg>
              </div>
              <!-- Mini orbit ring -->
              <div class="absolute -inset-1 rounded-full border border-primary/20 animate-orbit" style="animation-duration: 4s;" />
            </div>
            <span class="font-bold text-lg tracking-tight">
              Git<span class="text-primary">Orbit</span>
            </span>
          </a>

          <!-- Nav Links -->
          <div class="flex items-center gap-1 sm:gap-2">
            <a
              href="/setup"
              class="px-3 py-2 text-sm text-text-secondary hover:text-foreground transition-colors rounded-md hover:bg-secondary/50"
            >
              Setup
            </a>
            <a
              href="/dashboard"
              class="px-3 py-2 text-sm text-text-secondary hover:text-foreground transition-colors rounded-md hover:bg-secondary/50"
            >
              Dashboard
            </a>
            <a
              href="https://github.com/chirag127/gitorbit"
              target="_blank"
              rel="noopener noreferrer"
              class="ml-2 p-2 text-text-muted hover:text-foreground transition-colors rounded-md hover:bg-secondary/50"
              aria-label="GitHub repository"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- ═══════════ Page Content ═══════════ -->
    <main class="relative z-10 flex-1">
      <slot />
    </main>

    <!-- ═══════════ Footer ═══════════ -->
    <footer class="relative z-10 border-t border-border/60 glass mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-primary-light" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="12" cy="12" r="3" />
              </svg>
            </div>
            <p class="text-sm text-text-muted">
              &copy; {new Date().getFullYear()} GitOrbit. Zero-backend AI orchestration.
            </p>
          </div>
          <div class="flex items-center gap-6">
            <a
              href="/privacy"
              class="text-sm text-text-muted hover:text-text-secondary transition-colors"
            >
              Privacy
            </a>
            <a
              href="/terms"
              class="text-sm text-text-muted hover:text-text-secondary transition-colors"
            >
              Terms
            </a>
            <a
              href="mailto:whyiswhen@gmail.com"
              class="text-sm text-text-muted hover:text-text-secondary transition-colors"
            >
              Contact
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
